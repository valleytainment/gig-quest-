# Gig Quest — copy to .env.local and fill in as needed.
# Never commit .env.local or real secrets.

# Optional: Gemini API key (legacy scaffold; not required for landing/intake)
GEMINI_API_KEY=

# Phase 3+: Firestore-backed intake (default off until emulator/e2e proven)
VITE_ENABLE_FIRESTORE_INTAKE=false

# Optional: disable Vite HMR (useful in some hosted dev environments)
# DISABLE_HMR=true
