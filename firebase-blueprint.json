{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform, either an artist or an admin.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["artist", "admin"] },
        "xp": { "type": "number" },
        "level": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Event": {
      "title": "Event",
      "description": "An event that artists can sign up for.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "closed"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "date", "location", "status", "createdBy", "createdAt"]
    },
    "Submission": {
      "title": "Submission",
      "description": "An artist's application to perform at an event.",
      "type": "object",
      "properties": {
        "eventId": { "type": "string" },
        "artistId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "waitlisted", "rejected"] },
        "portfolioUrl": { "type": "string", "format": "uri" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "reviewedAt": { "type": "string", "format": "date-time" },
        "reviewedBy": { "type": "string" }
      },
      "required": ["eventId", "artistId", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["submission_update", "new_event"] }
      },
      "required": ["userId", "title", "message", "read", "createdAt", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/events/{eventId}": {
      "schema": { "$ref": "#/entities/Event" },
      "description": "Stores events created by admins."
    },
    "/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/Submission" },
      "description": "Stores artist submissions for events."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Stores notifications for users."
    }
  }
}
